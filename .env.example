# SolarOps — Environment Variables
# Copy to .env and fill in real values. Never commit .env.

# PostgreSQL / TimescaleDB (analytics only — not n8n backend)
POSTGRES_USER=solarops
POSTGRES_PASSWORD=PLACEHOLDER
POSTGRES_DB=solarops

# n8n (backend: SQLite, stored in n8n_data volume)
N8N_USER=admin
N8N_PASSWORD=PLACEHOLDER
N8N_ENCRYPTION_KEY=PLACEHOLDER_32_CHAR_RANDOM_STRING

# Grafana
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=PLACEHOLDER

# Notion — add integration token via n8n Credentials UI, not here
# Database IDs: copy from each DB's Notion URL
# NOTION_TOKEN=secret_xxx
# NOTION_PLANTS_DB_ID=xxx
# NOTION_ASSETS_DB_ID=xxx
# NOTION_DAILY_PERF_DB_ID=xxx
# NOTION_TICKETS_DB_ID=xxx
# NOTION_PM_TICKETS_DB_ID=xxx
# NOTION_REPORTS_DB_ID=xxx
# NOTION_AUDIT_LOG_DB_ID=xxx

# SynaptiQ (mock during development)
# SYNAPTIQ_API_URL=http://mock-api:8000
# SYNAPTIQ_API_TOKEN=PLACEHOLDER
